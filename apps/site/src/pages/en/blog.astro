---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import { getFormattedDate } from "@/utils/all";

const entries = (await getCollection("blog_en", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);

const blogDescription =
  "English EdgeEver notes about Cloudflare self-hosting, Evernote migration, product updates, and AI Agent workflows.";

const blogUrl = new URL(Astro.url.pathname, Astro.site).toString();
const blogJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "EdgeEver Blog",
  url: blogUrl,
  inLanguage: "en-US",
  description: blogDescription,
};
---

<Layout title="Blog" description={blogDescription} jsonLd={blogJsonLd}>
  <Container>
    <section class="mx-auto max-w-4xl py-16 md:py-24">
      <p class="text-sm font-semibold text-brand-text">EdgeEver Blog</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-950 md:text-5xl">Blog</h1>

      <div class="mt-10 grid gap-4">
        {
          entries.map((entry) => (
            <a
              href={`/en/blog/${entry.slug}`}
              class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-brand-border hover:shadow-lg"
            >
              <div class="flex flex-wrap items-center gap-3 text-sm text-slate-500">
                <span>{entry.data.category}</span>
                <span>·</span>
                <time datetime={entry.data.publishDate.toISOString()}>
                  {getFormattedDate(entry.data.publishDate)}
                </time>
              </div>
              <h2 class="mt-3 text-2xl font-bold text-slate-900 transition group-hover:text-brand-text">
                {entry.data.title}
              </h2>
              <p class="mt-3 text-base leading-7 text-slate-600">
                {entry.data.snippet}
              </p>
            </a>
          ))
        }
      </div>
    </section>
  </Container>
</Layout>
