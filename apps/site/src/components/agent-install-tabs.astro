---
import { Icon } from "astro-icon/components";

const { locale = "zh-CN" } = Astro.props;
const isEnglish = locale === "en-US";

const copy = isEnglish
  ? {
      chooseOne: "Choose either option to complete deployment.",
      oneClick: "Option B: Deploy from a Fork",
      agent: "Option A: AI Agent deployment",
      recommended: "Recommended",
      oneClickIntro:
        "Complete deployment in 4 steps: Fork EdgeEver, import it into Cloudflare Workers & Pages, configure the required resources, then run and verify the first build. See the online deployment guide for details.",
      forkButton: "Fork EdgeEver on GitHub",
      oneClickGuide: "Open the online deployment guide",
      oneClickGuideHref:
        "https://github.com/tianma-if/edgeever/blob/main/docs/deploy-cloudflare-button.md",
      agentIntro:
        "Copy the prompt below to an AI Agent configured with GitHub and Cloudflare MCP servers, plugins, or other integrations.",
      promptLabel: "Prompt",
      copyPrompt: "Copy prompt",
      copying: "Copying...",
      copied: "Copied",
      copyFailed: "Copy failed",
      billingNotice:
        "Heads up: Cloudflare R2, D1, and Workers may ask you to add a Visa card even when you use the free quotas.",
      promptText:
        "Deploy EdgeEver online:\n1. Fork https://github.com/tianma-if/edgeever.\n2. Import the Fork into Cloudflare Workers & Pages.\n3. Configure D1 DB, R2 RESOURCES, the EDGE_EVER_AUTH_PASSWORD Worker Secret, and Workers Builds using docs/agent-deploy-cloudflare.md.\n4. Start the first build, verify the health endpoint and login, then run Update deployed EdgeEver once.",
    }
  : {
      chooseOne: "以下两种方案任选其一即可完成部署。",
      oneClick: "方案二：Fork 后在线部署",
      agent: "方案一：AI Agent 一句话部署",
      recommended: "推荐",
      oneClickIntro: "共 4 步完成部署：Fork EdgeEver、导入 Cloudflare Workers & Pages、配置所需资源、启动并验证首次构建。详细操作请查看在线部署文档。",
      forkButton: "在 GitHub Fork EdgeEver",
      oneClickGuide: "查看在线部署文档",
      oneClickGuideHref:
        "https://github.com/tianma-if/edgeever/blob/main/docs/deploy-cloudflare-button.zh-CN.md",
      agentIntro: "将下方提示词复制给已配置 GitHub、Cloudflare MCP、插件或其他可用集成的 AI Agent。",
      promptLabel: "提示词",
      copyPrompt: "复制提示词",
      copying: "复制中...",
      copied: "已复制",
      copyFailed: "复制失败",
      billingNotice:
        "提示：Cloudflare 的 R2、D1 和 Worker 即使使用免费额度，开通或使用时也可能要求绑定 Visa 卡。国内用户可考虑使用招商银行多币种卡绑定。",
      promptText:
        "请在线完成 EdgeEver 部署：\n1. Fork https://github.com/tianma-if/edgeever。\n2. 将这个 Fork 导入 Cloudflare Workers & Pages。\n3. 按照 docs/agent-deploy-cloudflare.zh-CN.md 配置 D1 DB、R2 RESOURCES、EDGE_EVER_AUTH_PASSWORD Worker Secret 和 Workers Builds。\n4. 启动首次构建，验证健康检查和登录，然后手动运行一次 Update deployed EdgeEver。",
    };
---

<section class="not-prose relative left-1/2 my-10 w-[min(92vw,960px)] -translate-x-1/2" data-agent-install-tabs>
  <p class="mb-6 text-center text-lg font-semibold text-slate-700">{copy.chooseOne}</p>

  <div class="mx-auto grid max-w-4xl grid-cols-1 border-b border-slate-200 text-sm font-semibold sm:grid-cols-2 sm:text-base">
    <button
      class="agent-install-tab active relative px-3 py-4 text-brand transition hover:text-brand-text"
      type="button"
      data-tab-target="agent"
      aria-selected="true">
      <span>{copy.agent}</span>
      <span class="ml-1 rounded-full bg-brand/10 px-2 py-0.5 text-xs text-brand">{copy.recommended}</span>
    </button>
    <button
      class="agent-install-tab relative px-3 py-4 text-slate-500 transition hover:text-brand-text"
      type="button"
      data-tab-target="one-click"
      aria-selected="false">
      {copy.oneClick}
    </button>
  </div>

  <div class="mt-8 overflow-hidden rounded-[28px] bg-slate-100 px-6 py-8 sm:px-10 md:px-14">
    <div class="agent-install-panel hidden" data-tab-panel="one-click">
      <p class="mx-auto max-w-3xl text-center text-lg leading-9 text-slate-600">{copy.oneClickIntro}</p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          class="inline-flex items-center gap-2 rounded-xl bg-[#24292f] px-7 py-3 text-base font-semibold text-white shadow-[0_14px_30px_-18px_rgba(36,41,47,0.35)] transition hover:-translate-y-0.5 hover:bg-[#161b22]"
          href="https://github.com/tianma-if/edgeever/fork"
          target="_blank"
          rel="noopener">
          <Icon class="h-5 w-5" name="simple-icons:github" />
          {copy.forkButton}
        </a>
        <a
          class="text-sm font-semibold text-brand-text underline decoration-brand-border underline-offset-4 hover:text-brand"
          href={copy.oneClickGuideHref}
          target="_blank"
          rel="noopener">
          {copy.oneClickGuide}
        </a>
      </div>
    </div>

    <div class="agent-install-panel" data-tab-panel="agent">
      <p class="mx-auto mb-8 max-w-3xl text-center text-lg leading-9 text-slate-600">
        {copy.agentIntro}
      </p>

      <div class="mx-auto max-w-3xl rounded-2xl bg-white p-6 shadow-sm">
        <p class="text-sm font-medium text-slate-400">{copy.promptLabel}</p>
        <pre class="mt-4 whitespace-pre-wrap break-words font-mono text-base leading-8 text-slate-900">{copy.promptText}</pre>
      </div>

      <div class="mt-8 flex justify-center">
        <button
          class="agent-install-copy inline-flex items-center gap-2 rounded-full bg-brand px-8 py-3 text-base font-semibold text-white shadow-[0_14px_30px_-18px_rgb(var(--edgeever-brand-rgb)/0.85)] transition hover:-translate-y-0.5 hover:bg-brand-hover"
          type="button"
          data-copy-text={copy.promptText}
          data-copy-default={copy.copyPrompt}
          data-copy-copying={copy.copying}
          data-copy-copied={copy.copied}
          data-copy-failed={copy.copyFailed}>
          <Icon class="h-5 w-5" name="bx:bx-copy" />
          <span data-copy-label>{copy.copyPrompt}</span>
        </button>
      </div>

      <div class="mx-auto mt-5 flex max-w-3xl gap-2 rounded-xl border border-amber-200/80 bg-amber-50/70 px-3 py-2 text-xs leading-5 text-amber-900">
        <Icon class="mt-0.5 h-4 w-4 shrink-0 text-amber-600" name="bx:bx-credit-card" />
        <p>{copy.billingNotice}</p>
      </div>
    </div>

  </div>
</section>

<script is:inline>
  const copyTextToClipboard = async (text) => {
    if (navigator.clipboard && window.isSecureContext) {
      await navigator.clipboard.writeText(text);
      return;
    }

    const textarea = document.createElement("textarea");
    textarea.value = text;
    textarea.setAttribute("readonly", "");
    textarea.style.position = "fixed";
    textarea.style.left = "-9999px";
    textarea.style.top = "0";
    document.body.appendChild(textarea);
    textarea.focus();
    textarea.select();

    const copied = document.execCommand("copy");
    document.body.removeChild(textarea);

    if (!copied) {
      throw new Error("Copy command failed");
    }
  };

  const initAgentInstallTabs = () => {
    document.querySelectorAll("[data-agent-install-tabs]").forEach((root) => {
      if (root.getAttribute("data-agent-install-ready") === "true") return;
      root.setAttribute("data-agent-install-ready", "true");

      const tabs = Array.from(root.querySelectorAll("[data-tab-target]"));
      const panels = Array.from(root.querySelectorAll("[data-tab-panel]"));

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const target = tab.getAttribute("data-tab-target");

          tabs.forEach((item) => {
            const isActive = item === tab;
            item.setAttribute("aria-selected", String(isActive));
            item.classList.toggle("active", isActive);
            item.classList.toggle("text-brand", isActive);
            item.classList.toggle("text-slate-500", !isActive);
          });

          panels.forEach((panel) => {
            panel.classList.toggle("hidden", panel.getAttribute("data-tab-panel") !== target);
          });
        });
      });

      root.querySelectorAll("[data-copy-text]").forEach((button) => {
        button.addEventListener("click", async () => {
          const text = button.getAttribute("data-copy-text") || "";
          const label = button.querySelector("[data-copy-label]");

          const defaultLabel = button.getAttribute("data-copy-default") || "Copy";
          const copyingLabel = button.getAttribute("data-copy-copying") || "Copying...";
          const copiedLabel = button.getAttribute("data-copy-copied") || "Copied";
          const failedLabel = button.getAttribute("data-copy-failed") || "Copy failed";

          if (label) label.textContent = copyingLabel;

          try {
            await copyTextToClipboard(text);
            if (label) label.textContent = copiedLabel;
            window.setTimeout(() => {
              if (label) label.textContent = defaultLabel;
            }, 1600);
          } catch {
            if (label) label.textContent = failedLabel;
          }
        });
      });
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAgentInstallTabs);
  } else {
    initAgentInstallTabs();
  }
</script>

<style>
  .agent-install-tab.active::after {
    position: absolute;
    right: 0;
    bottom: -1px;
    left: 0;
    height: 3px;
    border-radius: 999px;
    background: var(--color-brand);
    content: "";
  }
</style>
